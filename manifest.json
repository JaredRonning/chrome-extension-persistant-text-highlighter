{
  "manifest_version": 3,
  "name": "Persistent Page Highlighter",
  "version": "1.0",
  "description": "Highlight saved text snippets on any webpage, every time you visit.",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "background": {
    "service_worker": "dist/background/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
